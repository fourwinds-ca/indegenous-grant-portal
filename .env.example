# Supabase Configuration
# Get these from your Supabase project settings at https://app.supabase.com

# Supabase Database URL (PostgreSQL connection string)
# Found in: Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase Project URL
# Found in: Project Settings > API > Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon/Public Key
# Found in: Project Settings > API > Project API keys > anon public
SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (for server-side operations)
# Found in: Project Settings > API > Project API keys > service_role
# KEEP THIS SECRET - Do not expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session Secret (for Express sessions)
# Generate a random secret: openssl rand -base64 32
SESSION_SECRET=your-random-session-secret-here

# Server Configuration (Optional)
# Default port is 5000 if not specified
PORT=5000

# Application URL (for OAuth redirects)
# Use your production domain or localhost for development
APP_URL=http://localhost:5000
